CC=gcc
ACTION_PATH=./action
BENCHMARK_PATH=./benchmark
MONITOR_PATH=./monitor
ACTION_OBJS = $(ACTION_PATH)/action.o
CFLAGS=-fPIC -Wall -O2
LDFLAGS= -L $(ACTION_PATH) -laction -L $(MONITOR_PATH) -lmonitor -L $(BENCHMARK_PATH) -lbenchmark -Wl,-rpath=$(BENCHMARK_PATH) -Wl,-rpath=$(MONITOR_PATH) -ldl
TARGET=kmeans

all: benchmark/libbenchmark.so monitor/libmonitor.so action/libaction.a kmeans

# -------------------
# action
# -------------------
$(ACTION_PATH)/action.o: $(ACTION_PATH)/action.c
	$(CC) $(CFLAGS) -c $< -o $@

$(ACTION_PATH)/libaction.a: $(ACTION_OBJS)
	ar rcs $@ $^

# -------------------
# benchmark
# -------------------

$(BENCHMARK_PATH)/benchmark.o: $(BENCHMARK_PATH)/benchmark.c
	$(CC) $(CFLAGS) -c $< -o $(BENCHMARK_PATH)/benchmark.o

$(BENCHMARK_PATH)/libbenchmark.so: $(BENCHMARK_PATH)/benchmark.o
	$(CC) -shared $^ -o $(BENCHMARK_PATH)/libbenchmark.so 

# -------------------
# monitor
# -------------------
$(MONITOR_PATH)/monitor.o: $(MONITOR_PATH)/monitor.c
	$(CC) $(CFLAGS) -c $< -o $@

$(MONITOR_PATH)/libmonitor.so: $(MONITOR_PATH)/monitor.o
	$(CC) -shared $^ -o $@ -ldcgm


# -------------------
# kmeans
# -------------------
kmeans.o: kmeans.c
	$(CC) -c -I$(ACTION_PATH) $< -o $@

$(TARGET):kmeans.o $(ACTION_PATH)/libaction.a
	$(CC) kmeans.o $(LDFLAGS) -o $@

clean:
	rm -f ./kmeans
	rm -f ./benchmark/*.so
	rm -f ./action/*.a
	rm -f ./monitor/*.so
	



